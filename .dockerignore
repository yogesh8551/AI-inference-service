# Ignore heavy repository folders to keep the build context small
.git/
.github/
.gitignore
.gitmodules

# Ignore models directory to prevent copying large GGUF models into the build context
models/

# Ignore source code folders and tests (not needed for runtime binary deployment)
src/
common/
examples/
tests/
docs/
vendor/
pocs/
ci/
cmake/
benches/
app/

# Ignore IDE and OS metadata
.vs/
.vscode/
.idea/
.cache/
.DS_Store

# Ignore intermediate compile files
*.o
*.a
*.d
*.pyc
__pycache__/
